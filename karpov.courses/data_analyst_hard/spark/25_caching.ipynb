{
 "cells": [
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "ec01f534-8037-4107-b857-93ade5c5b3be",
   "metadata": {},
   "outputs": [],
   "source": [
    "#Spark connection with S3 options\n",
    "import os\n",
    "import socket\n",
    "from pyspark.sql import SparkSession\n",
    "\n",
    "# Замените следующие значения на свои credentials\n",
    "aws_access_key = \\"<YC_AWS_ACCESS_KEY_ID>\\"\n",
    "aws_secret_key = \\"<YC_AWS_SECRET_ACCESS_KEY>\\"\n",
    "\n",
    "#Бакет менять не нужно\n",
    "s3_bucket = \"kc-hardda-projects\"\n",
    "s3_endpoint_url = \"https://storage.yandexcloud.net\"\n",
    "\n",
    " \n",
    "APACHE_MASTER_IP = socket.gethostbyname(\"apache-spark-master-0.apache-spark-headless.apache-spark.svc.cluster.local\")\n",
    "APACHE_MASTER_URL = f\"spark://{APACHE_MASTER_IP}:7077\"\n",
    "POD_IP = os.environ[\"MY_POD_IP\"]\n",
    "SPARK_APP_NAME = f\"spark-{os.environ['HOSTNAME']}\"\n",
    "JARS = \"\"\"/nfs/env/lib/python3.8/site-packages/pyspark/jars/clickhouse-native-jdbc-shaded-2.6.5.jar, \n",
    "/nfs/env/lib/python3.8/site-packages/pyspark/jars/hadoop-aws-3.3.4.jar,\n",
    "/nfs/env/lib/python3.8/site-packages/pyspark/jars/aws-java-sdk-bundle-1.12.433.jar\n",
    "\"\"\"\n",
    "\n",
    "MEM = \"512m\"\n",
    "CORES = 1\n",
    " \n",
    "spark = SparkSession.\\\n",
    "        builder.\\\n",
    "        appName(SPARK_APP_NAME).\\\n",
    "        master(APACHE_MASTER_URL).\\\n",
    "        config(\"spark.executor.memory\", MEM).\\\n",
    "        config(\"spark.jars\", JARS).\\\n",
    "        config(\"spark.executor.cores\", CORES).\\\n",
    "        config(\"spark.driver.host\", POD_IP).\\\n",
    "        config(\"spark.hadoop.fs.s3a.access.key\", aws_access_key). \\\n",
    "        config(\"spark.hadoop.fs.s3a.secret.key\", aws_secret_key). \\\n",
    "        config(\"fs.s3a.endpoint\", \"https://storage.yandexcloud.net\").  \\\n",
    "        config(\"spark.hadoop.fs.s3a.impl\", \"org.apache.hadoop.fs.s3a.S3AFileSystem\"). \\\n",
    "        config(\"spark.hadoop.fs.s3a.path.style.access\", True). \\\n",
    "        config(\"spark.hadoop.fs.s3a.committer.name\", \"directory\"). \\\n",
    "        config(\"spark.hadoop.fs.s3a.aws.credentials.provider\", \"org.apache.hadoop.fs.s3a.SimpleAWSCredentialsProvider\"). \\\n",
    "        getOrCreate()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "5a57ed32-e54d-4468-9e3d-b12c9f08f709",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Чтение данных из S3 в DataFrame\n",
    "s3_file_name = \"orders.csv\"\n",
    "\n",
    "s3_file_key = s3_bucket + \"/shared/\" + s3_file_name\n",
    "\n",
    "from pyspark.sql.types import StructType, StructField, IntegerType, TimestampType, StringType\n",
    "\n",
    "schema = StructType([\n",
    "    StructField('order_id', IntegerType()),\n",
    "    StructField('order_date', TimestampType()),\n",
    "    StructField('order_customer_id', IntegerType()),\n",
    "    StructField('order_status', StringType())\n",
    "])\n",
    "\n",
    "df_csv = spark.read.csv(f\"s3a://{s3_file_key}\", schema=schema)\n",
    "\n",
    "df_csv.show(3)\n",
    "df_csv.count()\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "e432bc6c-565b-4503-96ea-500660ebda71",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Кэшируем DF\n",
    "df_csv.cache()\n",
    "\n",
    "# Вызываем action, в нашем случае count \n",
    "df_csv.count()\n",
    "df_csv.show(3)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "8b498411-3595-4add-bc78-4becb2671089",
   "metadata": {},
   "outputs": [],
   "source": [
    "import timeit\n",
    "\n",
    "starttime = timeit.default_timer()\n",
    "df_csv.count()\n",
    "print(\"The time difference is :\", timeit.default_timer() - starttime)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "9d3a8ba4-27ae-4e2a-b985-bca9cf61854d",
   "metadata": {},
   "outputs": [],
   "source": [
    "from pyspark.storagelevel import StorageLevel\n",
    "\n",
    "help(StorageLevel)"
   ]
  },
  {
   "cell_type": "raw",
   "id": "c17e1ba6-abcd-4ed6-b49e-c0f082b19733",
   "metadata": {},
   "source": [
    "DISK_ONLY и DISK_ONLY_2 отличаются числом нод на которые будут реплицированы данные.\n",
    "При работе с большими датасетами и необходимости использования кэширования, рекомендуется использовать опцию DISK_ONLY.\n",
    "MEMORY_ONLY - самая быстрая и одновременно самая рискованная опция, так как Spark приложение может упасть с OOM (OutOfMemoryError)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "f642ff91-9355-40ce-8d73-f0a63760aeaf",
   "metadata": {},
   "outputs": [],
   "source": [
    "from pyspark.storagelevel import StorageLevel\n",
    "\n",
    "# Кэшируем DF с явным указанием StorageClass. По умолчанию MEMORY_ONLY \n",
    "df_csv.persist(StorageLevel.MEMORY_AND_DISK)\n",
    "\n",
    "df_csv.count()\n",
    "df_csv.show(3)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "31f6df40-cdb7-4adb-a570-837f6fb27e8c",
   "metadata": {},
   "outputs": [],
   "source": [
    "import timeit\n",
    "\n",
    "starttime = timeit.default_timer()\n",
    "df_csv.count()\n",
    "print(\"The time difference is :\", timeit.default_timer() - starttime)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "7d8a7d9d-4c4f-4bd2-9fa2-3441d37973f3",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Выполняем unpersist. Очищяем память, после этого DF более не закеширован\n",
    "df_csv.unpersist()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "a3e7f5ad-1cec-4a92-94c2-4c18ad8c792a",
   "metadata": {},
   "outputs": [],
   "source": [
    "#Проверяем время выполнения простого count после unpersist, то есть DF больше не закеширован\n",
    "#Время выполнения должно отличаться, минимум, в два раза. При этом мы используем небольшой по объемы DF.\n",
    "#При работе с большими данными выигрыш за счет использования cache может идти на минуты, часы\n",
    "\n",
    "import timeit\n",
    "\n",
    "starttime = timeit.default_timer()\n",
    "df_csv.count()\n",
    "print(\"The time difference is :\", timeit.default_timer() - starttime)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "83d7c985-c8cb-4510-b898-765e71fec9d1",
   "metadata": {},
   "outputs": [],
   "source": [
    "spark.stop()"
   ]
  },
