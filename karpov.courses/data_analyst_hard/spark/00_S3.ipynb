   "id": "668cd520-d1c1-49bf-a78c-83c96f233b6e",
   "metadata": {},
   "outputs": [],
   "source": [
    "import boto3\n",
    "from botocore.exceptions import NoCredentialsError\n",
    "\n",
    "# Указываем credentials и параметры для работы с S3\n",
    "aws_access_key = \\"<YC_AWS_ACCESS_KEY_ID>\\"\n",
    "aws_secret_key = \\"<YC_AWS_SECRET_ACCESS_KEY>\\"\n",
    "s3_endpoint_url = \"https://storage.yandexcloud.net\"\n",
    "s3_bucket = \"kc-hardda-projects\"\n",
    "\n",
    "#В переменную student_directory необходимо подставить свой username в karpov.courses\n",
    "student_directory = '/replace_with_your_username/'\n",
    "\n",
    "\n",
    "# Инициализация клиента S3 с указанием конечной точки\n",
    "s3 = boto3.client('s3',\n",
    "                  aws_access_key_id=aws_access_key,\n",
    "                  aws_secret_access_key=aws_secret_key,\n",
    "                  endpoint_url=s3_endpoint_url)\n",
    "\n",
    "# Создание папки в S3 (путем создания пустого объекта с именем папки)\n",
    "try:\n",
    "    s3.put_object(Bucket=s3_bucket, Key=student_directory)\n",
    "    print(f\"Folder '{student_directory}' created in bucket '{s3_bucket}'\")\n",
    "except NoCredentialsError:\n",
    "    print(\"Invalid AWS credentials provided\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "340bf945-56c4-41b4-9c18-a618e254101e",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Получение списка объектов в S3-бакете и нужной директории\n",
    "response = s3.list_objects_v2(Bucket=s3_bucket, Prefix = student_directory)\n",
    "\n",
    "# Вывод списка объектов\n",
    "if 'Contents' in response:\n",
    "    print(f\"Objects in bucket '{s3_bucket}':\")\n",
    "    for obj in response['Contents']:\n",
    "        print(f\"- {obj['Key']}\")\n",
    "else:\n",
    "    print(f\"No objects found in bucket '{s3_bucket}'\")\n",
    "    \n",
    "    \n",
    "#У предыдущего метода есть ограничение, он возвращает не более 1000 объектов в бакете\n",
    "#Если у вас более 1000 объектов, необходимо использовать paginator\n",
    "\n",
    "print(\"Paginator:\")\n",
    "paginator = s3.get_paginator('list_objects_v2')\n",
    "pages = paginator.paginate(Bucket=s3_bucket, Prefix=student_directory)\n",
    "\n",
    "# Iterate through the objects and print their keys\n",
    "for page in pages:\n",
    "    for obj in page.get('Contents', []):\n",
    "        print(obj['Key'])"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "d13b4fb9-7807-4304-bd72-db8164752f14",
   "metadata": {},
   "outputs": [],
   "source": [
    "local_file_path = \"orders.csv\"\n",
    "s3_file_name = \"orders.csv\"\n",
    "s3_file_key = student_directory + s3_file_name\n",
    "\n",
    "\n",
    "# Загрузка файла из локальной системы в S3\n",
    "try:\n",
    "    s3.upload_file(local_file_path, s3_bucket, s3_file_key)\n",
    "    print(f\"File '{local_file_path}' uploaded to '{s3_file_key}'\")\n",
    "except FileNotFoundError:\n",
    "    print(f\"File '{local_file_path}' not found\")\n",
    "except NoCredentialsError:\n",
    "    print(\"Invalid S3 credentials provided\")\n",
    "    \n",
    "# Вновь получаем список объектов, чтобы проверить загрузку файла\n",
    "response = s3.list_objects_v2(Bucket=s3_bucket, Prefix = student_directory)\n",
    "if 'Contents' in response:\n",
    "    print(f\"Objects in bucket '{s3_bucket}':\")\n",
    "    for obj in response['Contents']:\n",
    "        print(f\"- {obj['Key']}\")\n",
    "else:\n",
    "    print(f\"No objects found in bucket '{s3_bucket}'\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "abf80e1c-f045-4dda-9f1f-ff4631356f6d",
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "from io import StringIO\n",
    "\n",
    "\n",
    "# Чтение CSV-файла из S3\n",
    "try:\n",
    "    s3_object = s3.get_object(Bucket=s3_bucket, Key=s3_file_key)\n",
    "    file_content = s3_object['Body'].read().decode('utf-8')\n",
    "    csv_data = StringIO(file_content)\n",
    "\n",
    "    # Загрузка данных из CSV в Pandas DataFrame\n",
    "    df = pd.read_csv(csv_data, header=None)\n",
    "    print(df.head(10))\n",
    "\n",
    "except Exception as e:\n",
    "    print(f\"Error: {e}\")"
   ]
  },
  {
