   "source": [
    "# Запись данных в S3\n",
    "s3_file_name = \"orders_test_write\"\n",
    "s3_file_key = s3_bucket + student_directory + s3_file_name\n",
    "print(s3_file_key)\n",
    "\n",
    "df_csv.write.format(\"csv\").save(f\"s3a://{s3_file_key}\", mode='overwrite')\n"
