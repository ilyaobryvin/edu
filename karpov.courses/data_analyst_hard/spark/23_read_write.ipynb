   "source": [
    "from pyspark.sql import Row\n",
    "\n",
    "df_courses = spark.createDataFrame([Row(**course) for course in courses])\n",
    "\n",
    "df_courses.show()"
   ]
  },
  {
   "cell_type": "code",
