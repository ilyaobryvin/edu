   "source": [
    "#Применяя partionBy далее мы экономим время и ресурсы на чтении данных\n",
    "#Если указать фильтр, то мы вычитаем только данные из нужной партиции\n",
    "\n",
    "df_orders_parquet = spark. \\\n",
