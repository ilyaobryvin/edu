   "cell_type": "code",
   "execution_count": null,
   "id": "edecaf60-4e14-4a5d-aa66-a56194c7b011",
   "metadata": {},
   "outputs": [],
   "source": [
    "#С помощью coalesce управляем числом партиций, числом файлов, которые получим при записи\n",
    "#Добавляем header\n",
    "\n",
    "df_courses. \\\n",
    "    coalesce(1). \\\n",
    "    write. \\\n",
    "    format('csv'). \\\n",
    "    save(f's3a://kc-hardda-projects/{student_directory}/courses_csv/', mode='overwrite', header=True)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "d40c598d-983b-48f2-ad60-c8a15344a7f7",
   "metadata": {},
   "outputs": [],
   "source": [
    "#Также можно сразу сжать файлы\n",
    "#Поддерживаются разные codecs: bzip2, gzip, lz4, snappy, deflate\n",
    "#https://spark.apache.org/docs/3.1.2/api/python/reference/api/pyspark.sql.DataFrameWriter.csv.html#pyspark.sql.DataFrameWriter.csv\n",
    "\n",
    "df_courses. \\\n",
    "    coalesce(1). \\\n",
    "    write. \\\n",
    "    csv(\n",
    "        f's3a://kc-hardda-projects/{student_directory}/courses_csv_gzip/', \n",
    "        mode='overwrite', \n",
    "        compression='gzip',\n",
    "        header=True\n",
    "    )"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "c0e02c8f-b9c5-4bc6-921b-123b06ee7226",
   "metadata": {},
   "outputs": [],
   "source": [
    "#Можно использовать options для передачи настроек при записи\n",
    "df_courses. \\\n",
    "    coalesce(1). \\\n",
    "    write. \\\n",
    "    mode('overwrite'). \\\n",
    "    options(sep=';', header=True, compression='gzip'). \\\n",
    "    csv(f's3a://kc-hardda-projects/{student_directory}/courses_csv_gzip/')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "92ad035a-6643-4c48-aca3-74633ffa9e95",
   "metadata": {},
   "outputs": [],
   "source": [
    "#csv и json подходят для небольших тестовых данных\n",
    "#В проде рекомендуется использовать форматы parquet или orc\n",
    "\n",
    "help(df_courses.write.parquet)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "e71ee560-4f08-400d-bd4f-fefeaeb60c6a",
   "metadata": {},
   "outputs": [],
   "source": [
    "#В данном случае мы выбираем поведение overwrite, если данные уже существуют\n",
    "#Возможны варианты: \n",
    "#append - дописываем данные\n",
    "#ignore - ничего не делать, если есть данные в таргет \n",
    "#error - выдать ошибку, если есть данные в таргет. Данный режим применяется по умолчанию.\n",
    "#Поэкспериментируйте с различными режимами, поменяйте самостоятельно параметр mode\n",
    "df_courses. \\\n",
    "    coalesce(1). \\\n",
    "    write. \\\n",
    "    parquet(\n",
    "        f's3a://kc-hardda-projects/{student_directory}/courses_parquet/', \n",
    "        mode='overwrite'\n",
    "    )"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "10d37b1b-7154-4357-b727-f907dc50ac9d",
   "metadata": {},
   "outputs": [],
   "source": [
    "#При записи DataFrame нужно помнить о двух важных функциях - coalesce и repartition\n",
    "#Coalesce используют чтобы сократить число партиций, а значит и число файлов при записи\n",
    "#repartition при записи используют чаще для увеличения числа партиций/файлов при записи, \n",
    "#либо для более равномерного распределения данных внутри партиций/файлов,\n",
    "#если в результате преобразований число данных значительно отличается по партициям\n",
    "#Coalesce обычно используют чтобы избежать shuffle данных, repartition предполагает shuffle\n",
    "\n",
    "df_courses. \\\n",
    "    repartition(2). \\\n",
    "    write. \\\n",
    "    parquet(\n",
    "        f's3a://kc-hardda-projects/{student_directory}/courses_parquet/', \n",
    "        mode='overwrite'\n",
    "    )"
   ]
  },
  {
   "cell_type": "code",
