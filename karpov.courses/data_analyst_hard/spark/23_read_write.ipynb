   "id": "e18671bf-cc89-4cc5-9226-bf6e43a4ccf0",
   "metadata": {},
   "outputs": [],
   "source": [
    "#Spark connection with S3 options\n",
    "import os\n",
    "import socket\n",
    "from pyspark.sql import SparkSession\n",
    "\n",
    "# Замените следующие значения на свои credentials\n",
    "aws_access_key = \\"<YC_AWS_ACCESS_KEY_ID>\\"\n",
    "aws_secret_key = \\"<YC_AWS_SECRET_ACCESS_KEY>\\"\n",
    "s3_bucket = \"kc-hardda-projects\"\n",
    "s3_endpoint_url = \"https://storage.yandexcloud.net\"\n",
    " \n",
    "APACHE_MASTER_IP = socket.gethostbyname(\"apache-spark-master-0.apache-spark-headless.apache-spark.svc.cluster.local\")\n",
    "APACHE_MASTER_URL = f\"spark://{APACHE_MASTER_IP}:7077\"\n",
    "POD_IP = os.environ[\"MY_POD_IP\"]\n",
    "SPARK_APP_NAME = f\"spark-{os.environ['HOSTNAME']}\"\n",
    "JARS = \"\"\"/nfs/env/lib/python3.8/site-packages/pyspark/jars/clickhouse-native-jdbc-shaded-2.6.5.jar, \n",
    "/nfs/env/lib/python3.8/site-packages/pyspark/jars/hadoop-aws-3.3.4.jar,\n",
    "/nfs/env/lib/python3.8/site-packages/pyspark/jars/aws-java-sdk-bundle-1.12.433.jar\n",
    "\"\"\"\n",
    "\n",
    "MEM = \"512m\"\n",
    "CORES = 1\n",
    " \n",
    "spark = SparkSession.\\\n",
    "        builder.\\\n",
    "        appName(SPARK_APP_NAME).\\\n",
    "        master(APACHE_MASTER_URL).\\\n",
    "        config(\"spark.executor.memory\", MEM).\\\n",
    "        config(\"spark.jars\", JARS).\\\n",
    "        config(\"spark.executor.cores\", CORES).\\\n",
    "        config(\"spark.driver.host\", POD_IP).\\\n",
    "        config(\"spark.hadoop.fs.s3a.access.key\", aws_access_key). \\\n",
    "        config(\"spark.hadoop.fs.s3a.secret.key\", aws_secret_key). \\\n",
    "        config(\"fs.s3a.endpoint\", \"https://storage.yandexcloud.net\").  \\\n",
    "        config(\"spark.hadoop.fs.s3a.impl\", \"org.apache.hadoop.fs.s3a.S3AFileSystem\"). \\\n",
    "        config(\"spark.hadoop.fs.s3a.committer.name\", \"directory\"). \\\n",
    "        config(\"spark.hadoop.fs.s3a.path.style.access\", True). \\\n",
    "        config(\"spark.hadoop.fs.s3a.aws.credentials.provider\", \"org.apache.hadoop.fs.s3a.SimpleAWSCredentialsProvider\"). \\\n",
    "        getOrCreate()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "668cd520-d1c1-49bf-a78c-83c96f233b6e",
   "metadata": {},
   "outputs": [],
   "source": [
    "#Пример с базовым чтением json и записью в parquet\n",
    "\n",
    "#В переменную student_directory необходимо подставить свой username в karpov.courses\n",
    "student_directory = 'replace_with_your_username'\n",
    "\n",
    "df_orders_json = spark.read.json('s3a://kc-hardda-projects/shared/orders_json.txt')\n",
    "df_orders_json.show(3)\n",
    "\n",
    "df_orders_json.coalesce(1).write.parquet(f\"s3a://kc-hardda-projects/{student_directory}/orders_parquet/\", mode='overwrite')\n",
    "\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "5726c224-a085-4091-b4ab-35388e217b68",
   "metadata": {},
   "outputs": [],
   "source": [
    "#Читаем данные из parquet\n",
    "df_orders_parquet = spark.read.parquet(f\"s3a://kc-hardda-projects/{student_directory}/orders_parquet/\")\n",
    "df_orders_parquet.show(3)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "9efdd8ab-eeb6-49e9-ae8a-a4aae11ca5b1",
   "metadata": {},
   "outputs": [],
   "source": [
    "#Помним о том, что можем указывать схему при чтении данных\n",
    "schema = \"\"\"\n",
    "    order_id INT,\n",
    "    order_date TIMESTAMP,\n",
    "    order_customer_id INT,\n",
    "    order_status STRING\n",
    "\"\"\"\n",
    "\n",
    "spark.read.schema(schema).csv('s3a://kc-hardda-projects/shared/orders.csv').show(3)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "21bf3227-eb6d-4fc0-b9c0-da657a4ae0eb",
   "metadata": {},
   "outputs": [],
   "source": [
    "#Схему можно указать и так\n",
    "df_csv = spark.read.csv('s3a://kc-hardda-projects/shared/orders.csv', schema=schema)\n",
    "df_csv.show(3)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "4e1ecff0-680d-46a2-bf37-d3a0990222e7",
   "metadata": {},
   "outputs": [],
   "source": [
    "#Также полезно знать как задавать схему, используя StructType и StructField\n",
    "from pyspark.sql.types import StructType, StructField, IntegerType, TimestampType, StringType\n",
    "\n",
    "schema = StructType([\n",
    "    StructField('order_id', IntegerType()),\n",
    "    StructField('order_date', TimestampType()),\n",
    "    StructField('order_customer_id', IntegerType()),\n",
    "    StructField('order_status', StringType())\n",
    "])\n",
    "\n",
    "df_csv = spark.read.csv('s3a://kc-hardda-projects/shared/orders.csv', schema=schema)\n",
    "df_csv.show(3)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "a4eb586c-b0f6-4fee-aaf0-06d148e4038c",
   "metadata": {},
   "outputs": [],
   "source": [
    "#Также можно попробовать автоматически определить типы данных\n",
    "#Данный способ не рекомендуется. Для определения схемы файл вычитывается целиком.\n",
    "\n",
    "df_csv = spark.read.option('inferSchema', True). \\\n",
    "    csv('s3a://kc-hardda-projects/shared/orders.csv'). \\\n",
    "    toDF('order_id', 'order_date', 'order_customer_id', 'order_status')\n",
    "\n",
    "df_csv.show(3)\n",
    "df_csv.count()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "7740afec-9ea4-4293-b20f-ddf42fdea0f0",
   "metadata": {},
   "outputs": [],
   "source": [
    "#Список колонок можно задать заранее и передать как параметр при создании DataFrame\n",
    "\n",
    "columns = ['order_id', 'order_date', 'order_customer_id', 'order_status']\n",
    "\n",
    "df_csv = spark.read.option('inferSchema', True). \\\n",
    "    csv('s3a://kc-hardda-projects/shared/orders.csv'). \\\n",
    "    toDF(*columns)\n",
    "\n",
    "df_csv.show(3)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "ed51d8ad-aeb6-4bd8-a934-2b5d85a3e145",
   "metadata": {},
   "outputs": [],
   "source": [
    "#Отдельно можно задать разделитель, если он отличается от запятой по умолчанию\n",
    "#Также можно указать есть ли в файле header\n",
    "\n",
    "spark.read.csv('s3a://kc-hardda-projects/shared/orders.csv', sep=',', header=None, schema=schema).show(3)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "41a2a334-4012-46ec-8337-7a409e44dc49",
   "metadata": {},
   "outputs": [],
   "source": [
    "#Полный список поддерживаемых параметров можно узнать с помощью help\n",
    "\n",
    "help(spark.read.csv)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "805292ff-2012-496d-849a-de85c3f96327",
   "metadata": {},
   "outputs": [],
   "source": [
    "#Параметры при чтении можно передать и с помощью options\n",
    "\n",
    "df_csv = spark. \\\n",
    "    read. \\\n",
    "    options(sep=',', header=None, schema=schema). \\\n",
    "    csv('s3a://kc-hardda-projects/shared/orders.csv'). \\\n",
    "    toDF(*columns)\n",
    "\n",
    "df_csv.show(3)"
   ]
  },
