   "outputs": [],
   "source": [
    "#Также при записи можно указать параметр partitionBy(col_name)\n",
    "#обычно partitionBy используют для эффективной организации хранения больших данных\n",
    "#в качестве колонки для партиционирования обычно выбирают Date\n",
    "#в этом случае данные за каждую дату будут храниться в отдельной поддиректории-партиции \n",
    "\n",
    "from pyspark.sql.functions import date_format\n",
    "\n",
    "df_orders_parquet = spark.read.parquet(f's3a://kc-hardda-projects/{student_directory}/orders_parquet/')\n",
    "df_orders_parquet.show(3)\n",
    "\n",
    "df_orders_parquet. \\\n",
    "    coalesce(1). \\\n",
    "    write. \\\n",
    "    partitionBy(\"order_status\"). \\\n",
    "    parquet(f's3a://kc-hardda-projects/{student_directory}/orders_parquet_partitioned', mode='overwrite')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "cf86ad28-0ac7-4228-988d-fc29e73ade52",
   "metadata": {},
   "outputs": [],
   "source": [
    "import boto3\n",
    "from botocore.exceptions import NoCredentialsError\n",
    "\n",
    "# Замените следующие значения на свои credentials и пути к своим директориям. s3_bucket не меняем\n",
    "aws_access_key = \\"<YC_AWS_ACCESS_KEY_ID>\\"\n",
    "aws_secret_key = \\"<YC_AWS_SECRET_ACCESS_KEY>\\"\n",
    "s3_endpoint_url = \"https://storage.yandexcloud.net\"\n",
    "s3_bucket = \"kc-hardda-projects\"\n",
    "\n",
    "\n",
    "\n",
    "# Инициализация клиента S3 с указанием конечной точки\n",
    "s3 = boto3.client('s3',\n",
    "                  aws_access_key_id=aws_access_key,\n",
    "                  aws_secret_access_key=aws_secret_key,\n",
    "                  endpoint_url=s3_endpoint_url)\n",
    "\n",
    "# Получение списка объектов в S3-бакете\n",
    "response = s3.list_objects_v2(Bucket=s3_bucket, Prefix = student_directory)\n",
    "\n",
    "# Вывод списка объектов\n",
    "if 'Contents' in response:\n",
    "    print(f\"Objects in bucket '{s3_bucket}':\")\n",
    "    for obj in response['Contents']:\n",
    "        print(f\"- {obj['Key']}\")\n",
    "else:\n",
    "    print(f\"No objects found in bucket '{s3_bucket}'\")\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "fb33fb17-bfc0-444e-bb30-dc4232a67d49",
   "metadata": {},
   "outputs": [],
   "source": [
    "#partitionBy и repartition можно использовать вместе\n",
    "#в этом случае внутри каждой поддиректории/партиции получим число файлов равное числу партиций, которые указали в repartition\n",
    "\n",
    "df_orders_parquet. \\\n",
    "    repartition(2). \\\n",
    "    write. \\\n",
    "    partitionBy(\"order_status\"). \\\n",
    "    parquet(f's3a://kc-hardda-projects/{student_directory}/orders_parquet_partitioned', mode='overwrite')"
   ]
  },
